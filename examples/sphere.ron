// Smallest raymarch demo. Audio-modulated sphere displacement.

(
    version: 1,
    width: 720,
    height: 720,
    fps: 30,
    tone_map: aces,

    nodes: {
        "scene": (
            type: "raymarch",
            params: {
                "cam_z": 3.5,
                "radius": (feature: "rms", scale: 0.3, bias: 0.9),
                "displacement": (feature: "bass", scale: 0.15, bias: 0.05),
                "sky_top": [0.4, 0.5, 0.7, 1.0],
                "sky_bottom": [0.05, 0.02, 0.08, 1.0],
            },
        ),

        "glow": (
            type: "bloom",
            inputs: ["scene"],
            params: {
                "threshold": 0.6,
                "intensity": 0.4,
                "radius": 4.0,
            },
        ),
    },

    output: "glow",
)
