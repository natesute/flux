// Audio-reactive piece exercising most of the v0.2 chain:
//
//   noise ──▶ levels ──▶ displace ◀── noise2 (drives the warp)
//                          │
//                          ▼
//                       transform (slow rotation)
//                          │
//                          ▼
//                       feedback (long-lived trails)
//                          │
//                          ▼
//                         bloom
//                          │
//                          ▼
//                  chromatic_aberration
//                          │
//                          ▼
//                        grain
//
// `noise` builds the colored texture, `noise2` is a separate slow-moving
// grayscale noise used as a flow field. `displace` warps the colored
// noise by `noise2`'s luminance gradient, `feedback` keeps a long trail,
// and the post chain (transform → bloom → CA → grain) gives it a finished
// look. ACES tone mapping handles the highlights.

(
    version: 1,
    width: 1080,
    height: 1080,
    fps: 30,
    tone_map: aces,

    nodes: {
        "noise": (
            type: "noise",
            params: {
                "color_a": [0.05, 0.02, 0.20, 1.0],
                "color_b": [1.0, 0.55, 0.15, 1.0],
                "scale": (feature: "bass", scale: 1.5, bias: 2.0),
                "speed": 0.18,
                "octaves": 4.0,
                "contrast": 1.4,
                "intensity": 1.0,
            },
        ),

        "noise2": (
            type: "noise",
            params: {
                "color_a": [0.0, 0.0, 0.0, 1.0],
                "color_b": [1.0, 1.0, 1.0, 1.0],
                "scale": 2.0,
                "speed": 0.07,
                "octaves": 3.0,
                "contrast": 1.0,
                "intensity": 1.0,
            },
        ),

        "punchy": (
            type: "levels",
            inputs: ["noise"],
            params: {
                "gain": 0.85,
                "brightness": 0.0,
                "contrast": 1.1,
                "saturation": 1.2,
            },
        ),

        "warped": (
            type: "displace",
            inputs: ["punchy", "noise2"],
            params: {
                "amount": (feature: "rms", scale: 0.18, bias: 0.04),
                "mode": "derivative",
            },
        ),

        "spinning": (
            type: "transform",
            inputs: ["warped"],
            params: {
                "rotation": 0.001,
                "scale_x": 1.0,
                "scale_y": 1.0,
            },
        ),

        "trails": (
            type: "feedback",
            inputs: ["spinning"],
            params: {
                "decay": (feature: "treble", scale: -0.04, bias: 0.95),
                "zoom": 1.003,
                "rotation": 0.001,
                "mix_in": 0.45,
            },
        ),

        "glow": (
            type: "bloom",
            inputs: ["trails"],
            params: {
                "threshold": 0.75,
                "intensity": (feature: "rms", scale: 0.5, bias: 0.25),
                "radius": 5.0,
            },
        ),

        "ca": (
            type: "chromatic_aberration",
            inputs: ["glow"],
            params: {
                "amount": (feature: "bass", scale: 0.012, bias: 0.003),
            },
        ),

        "final": (
            type: "grain",
            inputs: ["ca"],
            params: {
                "amount": 0.025,
                "scale": 1.5,
            },
        ),
    },

    output: "final",
)
